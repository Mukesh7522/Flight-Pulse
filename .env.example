# ── Frontend (Vite/React) — safe to expose, RLS protects data ────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Ingestion (Python) — SERVICE ROLE KEY, never expose in frontend ──────────
# Use the Supabase connection pooler URL (port 6543) for high-frequency inserts
DATABASE_URL=postgresql://postgres.xxxx:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# ── OpenSky Network OAuth2 (optional — gives 10x more flight data)
# Register at https://opensky-network.org → My OpenSky → Client Credentials
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
